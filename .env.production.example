# Copier ce fichier en .env.production et remplir les valeurs

# Domaine principal (sans https://)
# compteur sera sur DOMAIN, inscription sur inscription.DOMAIN
DOMAIN=mondomaine.com

# Clé secrète AdonisJS (générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))")
APP_KEY=CHANGE_ME

# URL publique de l'API (interne Docker, pas besoin de changer)
APP_URL=http://api:3333

# Mot de passe PostgreSQL
DB_PASSWORD=CHANGE_ME

# Codes d'accès pour le compteur
STAFF_CODE=1234
ADMIN_CODE=1234
