# Copier ce fichier en .env.production et remplir les valeurs
# Sur le VPS : cp .env.production.example .env.production

# Clé secrète AdonisJS (générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))")
APP_KEY=CHANGE_ME

# URL publique de l'API (ex: https://api.mondomaine.com ou http://vps-ip:3333)
APP_URL=http://localhost:3333

# Mot de passe PostgreSQL
DB_PASSWORD=CHANGE_ME
